# ============================================
# Environment Variables Template
# ============================================
# Copy to .env.local and fill in your values

# ============================================
# Supabase (required for all scripts in /scripts)
# ============================================
SUPABASE_URL=https://pasuywntzuyomkwfagep.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # Settings → API → service_role
NEXT_PUBLIC_SUPABASE_URL=https://pasuywntzuyomkwfagep.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key       # Settings → API → anon/public

# ============================================
# Google Maps (required for geocode + scraper scripts)
# ============================================
GOOGLE_MAPS_API_KEY=your_key                      # Places + Geocoding APIs must be enabled
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_key

# ============================================
# Database
# ============================================
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ============================================
# Admin / cron (must match Vercel production for scripts that call /api/admin/*)
# ============================================
# ADMIN_SECRET=your-vercel-admin-secret

# ============================================
# PhonePe Payment Gateway
# ============================================
# Get from PhonePe Business Dashboard: https://business.phonepe.com/
PHONEPE_CLIENT_ID=your_client_id
PHONEPE_CLIENT_VERSION=1.0
PHONEPE_CLIENT_SECRET=your_client_secret

# Sandbox for development, false for production
PHONEPE_SANDBOX=true

# Base URL for payment redirects (optional; defaults to VERCEL_URL or NEXTAUTH_URL)
# PHONEPE_REDIRECT_BASE_URL=https://lokazen.in

# Webhook auth (configure in PhonePe dashboard; 5-20 chars username, 8-20 chars password)
PHONEPE_WEBHOOK_USERNAME=your_webhook_username
PHONEPE_WEBHOOK_PASSWORD=your_webhook_password

# For unauthenticated location report purchases (guest user ID in users table)
# PHONEPE_GUEST_USER_ID=uuid-of-guest-user

# Client-side: set true to load sandbox checkout script
NEXT_PUBLIC_PHONEPE_SANDBOX=true

# ============================================
# Meta (Facebook) — Pixel + Conversions API (Ads Manager)
# ============================================
# Browser: src/lib/tracking.ts + src/app/layout.tsx (fbq)
# NEXT_PUBLIC_META_PIXEL_ID=123456789012345
#
# Server (Conversions API — required for reliable attribution / iOS limits):
# Generate in Meta Events Manager → your Pixel/Dataset → Settings → Conversions API → Generate access token.
# META_ACCESS_TOKEN=EAAB...
# Optional: same ID as NEXT_PUBLIC (server can read NEXT_PUBLIC_* at build time on Vercel)
# META_PIXEL_ID=123456789012345
#
# Optional: Events Manager → Test events tab → copy code while validating
# META_CAPI_TEST_EVENT_CODE=TEST12345

# ============================================
# Email (Resend) — admin CRM, owner welcome, matched properties
# ============================================
# https://resend.com — verify your domain; use a verified from address
# RESEND_API_KEY=re_xxxx
# RESEND_FROM="GVS Ventures <noreply@yourdomain.com>"
# EMAIL_FROM="Lokazen <noreply@yourdomain.com>"  # fallback if RESEND_FROM not set
# EMAIL_REPLY_TO=ngventuresonline@gmail.com     # optional; defaults to ngventuresonline@gmail.com
# NEXT_PUBLIC_APP_URL=https://lokazen.in
