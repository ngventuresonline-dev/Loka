# ============================================
# Environment Variables Template
# ============================================
# Copy to .env.local and fill in your values

# ============================================
# Database
# ============================================
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ============================================
# PhonePe Payment Gateway
# ============================================
# Get from PhonePe Business Dashboard: https://business.phonepe.com/
PHONEPE_CLIENT_ID=your_client_id
PHONEPE_CLIENT_VERSION=1.0
PHONEPE_CLIENT_SECRET=your_client_secret

# Sandbox for development, false for production
PHONEPE_SANDBOX=true

# Base URL for payment redirects (optional; defaults to VERCEL_URL or NEXTAUTH_URL)
# PHONEPE_REDIRECT_BASE_URL=https://lokazen.in

# Webhook auth (configure in PhonePe dashboard; 5-20 chars username, 8-20 chars password)
PHONEPE_WEBHOOK_USERNAME=your_webhook_username
PHONEPE_WEBHOOK_PASSWORD=your_webhook_password

# For unauthenticated location report purchases (guest user ID in users table)
# PHONEPE_GUEST_USER_ID=uuid-of-guest-user

# Client-side: set true to load sandbox checkout script
NEXT_PUBLIC_PHONEPE_SANDBOX=true

# ============================================
# Email (Resend) — admin CRM, owner welcome, matched properties
# ============================================
# https://resend.com — verify your domain; use a verified from address
# RESEND_API_KEY=re_xxxx
# RESEND_FROM="GVS Ventures <noreply@yourdomain.com>"
# EMAIL_FROM="Lokazen <noreply@yourdomain.com>"  # fallback if RESEND_FROM not set
# EMAIL_REPLY_TO=ngventuresonline@gmail.com     # optional; defaults to ngventuresonline@gmail.com
# NEXT_PUBLIC_APP_URL=https://lokazen.in
