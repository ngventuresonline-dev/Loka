{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run vercel-build",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/refresh-intel-cache",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/ai/synthesize",
      "schedule": "0 2 */3 * *"
    },
    {
      "path": "/api/ai/insights/refresh",
      "schedule": "0 6 */3 * *"
    }
  ],
  "functions": {
    "src/app/api/dashboard/brand/intel-enrich/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/ai/synthesize/route.ts": {
      "maxDuration": 300
    }
  }
}
